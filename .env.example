# Copy to Netlify → Environment variables. Local dev: copy to .env.local

# Browser (NEXT_PUBLIC_* is embedded at build time)
NEXT_PUBLIC_EDITOR_PASSWORD=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_EDITOR_SHARED_KEY=

# API protection — must match NEXT_PUBLIC_EDITOR_SHARED_KEY for clients
EDITOR_SHARED_KEY=

# Multiset M2M (server only) — required for /api/localize and map endpoints. Netlify: scope must include Functions.
MULTISET_CLIENT_ID=
MULTISET_CLIENT_SECRET=

# AR / map query page (REST): approximate vertical field of view (degrees) for estimated intrinsics
NEXT_PUBLIC_CAMERA_VERTICAL_FOV=
# Send isRightHanded=false when your pose pipeline assumes LHS (Unity-style); omit or leave unset for default true
NEXT_PUBLIC_VPS_IS_RIGHT_HANDED=
# AR overlay: multiset pose → Three.js matrix (direct | unity | lhsReflection | invMapCam)
NEXT_PUBLIC_AR_LOCALIZE_POSE_MODE=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_GLBS_BUCKET=glb-assets
SUPABASE_AR_LOGS_BUCKET=ar-logs
