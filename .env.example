# Frontend (NEXT_PUBLIC_* is exposed to the browser)
NEXT_PUBLIC_EDITOR_PASSWORD=multiset-demo
# Leave empty so the browser uses same-origin API (same host as the page). Required for phone testing on LAN.
# Only set NEXT_PUBLIC_API_BASE_URL if the API is on a different origin than the page.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_EDITOR_SHARED_KEY=super-simple-shared-key

# Backend / Next.js server
PORT=3000
EDITOR_SHARED_KEY=super-simple-shared-key
MULTISET_CLIENT_ID=your_multiset_client_id
MULTISET_CLIENT_SECRET=your_multiset_client_secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_GLBS_BUCKET=glb-assets
