# Copy to Netlify → Environment variables. Local dev: copy to .env.local

# Browser (NEXT_PUBLIC_* is embedded at build time)
NEXT_PUBLIC_EDITOR_PASSWORD=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_EDITOR_SHARED_KEY=

# API protection — must match NEXT_PUBLIC_EDITOR_SHARED_KEY for clients
EDITOR_SHARED_KEY=

# Netlify: add in the dashboard (not .env.local). If you use per-scope limits, include "Functions" so API routes see these at runtime.
# AR page (@multisetai/vps) only: browser must authorize to Multiset; embeds creds in client bundle.
# Use a dedicated demo client or accept exposure. Must match server credentials if same Multiset app.
NEXT_PUBLIC_MULTISET_CLIENT_ID=
NEXT_PUBLIC_MULTISET_CLIENT_SECRET=
# AR: full map mesh uses heavy GPU; default off in code. Set "true" only on strong devices.
NEXT_PUBLIC_AR_SHOW_MESH=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_GLBS_BUCKET=glb-assets
